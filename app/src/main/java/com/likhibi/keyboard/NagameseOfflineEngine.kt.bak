    // Local bigram predictor: matches standard word transitions in Nagamese to recommend the next word instantly
    private val localBigrams = mapOf(
        "moi" to listOf("ase", "jabo", "bhal", "ahise", "khabo", "kobo"),
        "tumi" to listOf("ase", "ki", "jabo", "kobo", "keneka", "ahise"),
        "tai" to listOf("ase", "ahise", "koise", "jabo", "bisi", "hobo"),
        "bhal" to listOf("ase", "hobo", "manu", "kotha", "hoise"),
        "ki" to listOf("ase", "hoise", "kotha", "kori", "hobo"),
        "manu" to listOf("khan", "logote", "bhal", "ase", "pora"),
        "etu" to listOf("kotha", "bhal", "hobo", "hoise", "nombor"),
        "nagaland" to listOf("manu", "pora", "bhal", "te", "ase"),
        "ami" to listOf("khan", "ase", "jabo", "bhal", "ahise"),
        "kun" to listOf("ase", "ahise", "hobo", "koise"),
        "kori" to listOf("ase", "hobo", "thakibo", "pise"),
        "kotha" to listOf("ase", "kobo", "bhal", "hoise"),
        "aro" to listOf("ki", "bhal", "etu", "moi", "tumi"),
        "bisi" to listOf("bhal", "kotha", "hobo", "ase", "manu"),
        "ase" to listOf("na", "aro", "thik", "bhal", "khan"),
        "hobo" to listOf("na", "aro", "thik", "pise"),
        "hoise" to listOf("na", "aro", "thik", "pise")
    )

    /**
     * Attempts to fetch cached next-word suggestions from memory
     */
    fun getCachedSuggestions(contextKey: String): List<String>? {
        synchronized(geminiCache) {
            val cached = geminiCache[contextKey]
            if (cached != null) {
                Log.d("OfflineEngine", "Cache hit for '$contextKey': $cached")
            }
            return cached
        }
    }

    /**
     * Stores successful predictions from Gemini in memory for zero-latency reuse
     */
    fun cacheSuggestions(contextKey: String, suggestions: List<String>) {
        if (suggestions.isEmpty()) return
        synchronized(geminiCache) {
            geminiCache[contextKey] = suggestions
            Log.d("OfflineEngine", "Cached '$contextKey' -> $suggestions")
        }
    }

    /**
     * Dynamically registers a word typed by the user to personalize matches
     */
    fun learnWord(word: String) {
        val w = word.trim().lowercase()
        // Skip too short, too long, or non-alphabet strings
        if (w.length <= 1 || w.length > 20 || w.any { !it.isLetter() }) return
        
        // Skip if already a high-ranking dictionary word to save space
        if (localDictionary.containsKey(w) && (localDictionary[w] ?: 0) > 40) return

        synchronized(userWords) {
            val count = userWords[w] ?: 0
            userWords[w] = count + 1
            Log.d("OfflineEngine", "Learned word: '$w' (Count: ${count + 1})")
        }
    }

    /**
     * Performs instant local prefix-matching for actively-typing autocomplete (0ms delay)
     */
    fun getPrefixMatches(prefix: String): List<String> {
        val p = prefix.trim().lowercase()
        if (p.isEmpty()) return emptyList()

        val candidates = mutableListOf<Pair<String, Int>>()

        // 1. Check user-typed words and give them a priority weight boost
        synchronized(userWords) {
            for ((word, freq) in userWords) {
                if (word.startsWith(p)) {
                    candidates.add(word to (freq * 50 + 100))
                }
            }
        }

        // 2. Fetch matches from local precompiled vocabulary
        for ((word, freq) in localDictionary) {
            if (word.startsWith(p)) {
                candidates.add(word to freq)
            }
        }

        // 3. Remove duplicates, taking the highest frequency ranking
        val uniqueCandidates = candidates
            .groupBy { it.first }
            .map { entry -> entry.key to entry.value.maxOf { it.second } }

        // 4. Sort and yield the top 3 items
        val result = uniqueCandidates
            .sortedByDescending { it.second }
            .map { it.first }
            .take(3)
            
        Log.d("OfflineEngine", "Prefix matches for '$p': $result")
        return result
    }

    /**
     * Performs instant local next-word bigram prediction (0ms delay)
     */
    fun getLocalNextWordPredictions(lastWord: String): List<String> {
        val lw = lastWord.trim().lowercase()
        if (lw.isEmpty()) return getPopularWords()

        // 1. Fetch precompiled next-word bigrams
        val transitions = localBigrams[lw]
        if (transitions != null && transitions.isNotEmpty()) {
            Log.d("OfflineEngine", "Bigram transitions for '$lw': $transitions")
            return transitions.take(3)
        }

        // 2. Fallback to general popular words (filtered to make sure we don't repeat the same word)
        val fallback = getPopularWords().filter { it != lw }.take(3)
        Log.d("OfflineEngine", "Fallback transitions for '$lw': $fallback")
        return fallback
    }

    /**
     * Standard startup/fallback suggestion set
     */
    fun getPopularWords(): List<String> {
        return listOf("moi", "tumi", "ase")
    }
}
