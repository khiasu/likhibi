<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ime_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#12131A"
    android:orientation="vertical"
    android:paddingBottom="2dp">

    <!-- Premium glassmorphic Suggestion & Tools Bar -->
    <LinearLayout
        android:id="@+id/suggestion_bar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#1A1C24"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="6dp"
        android:elevation="3dp">

        <!-- Dynamic Menu / Close Toggle Button -->
        <TextView
            android:id="@+id/btn_toolbar_toggle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="❖"
            android:textColor="#00E5FF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackgroundBorderless" />

        <!-- Vertical Separator -->
        <View
            android:id="@+id/toolbar_divider"
            android:layout_width="1dp"
            android:layout_height="22dp"
            android:layout_marginHorizontal="2dp"
            android:background="#2E313D" />

        <!-- 1. Suggestions Container (Visible by default) -->
        <LinearLayout
            android:id="@+id/suggestions_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="visible">

            <!-- Suggestion 1 (Left) -->
            <TextView
                android:id="@+id/suggestion_1"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:background="?android:attr/selectableItemBackground"
                android:gravity="center"
                android:textColor="#A0A5B5"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end"
                android:clickable="true"
                android:focusable="true"/>

            <!-- Fine vertical separator 1 -->
            <View
                android:layout_width="1dp"
                android:layout_height="22dp"
                android:background="#2E313D" />

            <!-- Suggestion 2 (Center - OxygenOS Active Accent Highlight) -->
            <TextView
                android:id="@+id/suggestion_2"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1.2"
                android:layout_marginHorizontal="6dp"
                android:background="?android:attr/selectableItemBackground"
                android:gravity="center"
                android:textColor="#00E5FF"
                android:textStyle="bold"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end"
                android:clickable="true"
                android:focusable="true"/>

            <!-- Fine vertical separator 2 -->
            <View
                android:layout_width="1dp"
                android:layout_height="22dp"
                android:background="#2E313D" />

            <!-- Suggestion 3 (Right) -->
            <TextView
                android:id="@+id/suggestion_3"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:background="?android:attr/selectableItemBackground"
                android:gravity="center"
                android:textColor="#A0A5B5"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>

        <!-- 2. Keyboard Utility Tools Container (Hidden by default) -->
        <LinearLayout
            android:id="@+id/tools_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone">

            <!-- Clipboard Button -->
            <TextView
                android:id="@+id/btn_tool_clip"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:background="?android:attr/selectableItemBackground"
                android:gravity="center"
                android:text="Clipboard"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:clickable="true"
                android:focusable="true" />

            <!-- Themes Button -->
            <TextView
                android:id="@+id/btn_tool_theme"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:background="?android:attr/selectableItemBackground"
                android:gravity="center"
                android:text="Themes"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:clickable="true"
                android:focusable="true" />

            <!-- Settings Button -->
            <TextView
                android:id="@+id/btn_tool_settings"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:background="?android:attr/selectableItemBackground"
                android:gravity="center"
                android:text="Settings"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </LinearLayout>

    <!-- Sleek premium thin divider under suggestion bar -->
    <View
        android:id="@+id/bar_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#15161C" />

    <!-- Our high-performance programmatically styled custom keyboard view -->
    <com.likhibi.keyboard.CustomKeyboardView
        android:id="@+id/keyboard_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</LinearLayout>
