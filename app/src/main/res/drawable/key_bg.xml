<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <inset android:insetLeft="2dp" android:insetRight="2dp" android:insetTop="3dp" android:insetBottom="3dp">
            <shape>
                <solid android:color="#C0C3C8" />
                <corners android:radius="5dp" />
            </shape>
        </inset>
    </item>
    <item>
        <inset android:insetLeft="2dp" android:insetRight="2dp" android:insetTop="3dp" android:insetBottom="3dp">
            <layer-list>
                <item>
                    <shape>
                        <solid android:color="#999EA4" />
                        <corners android:radius="5dp" />
                    </shape>
                </item>
                <item android:bottom="1.5dp">
                    <shape>
                        <solid android:color="#FFFFFF" />
                        <corners android:radius="5dp" />
                    </shape>
                </item>
            </layer-list>
        </inset>
    </item>
</selector>
